@page
@model RegisterModel
@{
	ViewData["Title"] = "تسجيل حساب جديد";
}

<style>
	div {
		overflow-x: hidden;
	}
</style>
<head>
	<meta name="viewport" content="width=device-width, initial-scale=1">
</head>
<!-- اضبط الصفحة لتكون RTL -->
<div class="all" dir="auto">

	@* <h1 class="mb-4">@ViewData["Title"]</h1> *@

	<div class="row">
		<div class="d-flex align-items-center justify-content-center"
			 style="min-height: 70vh;">

			<div class="row w-100 justify-content-center">
				<div class="col-12 col-md-6 col-lg-4">

					@* <div class="col-md-4 " style="margin-left:50%" > *@
					<form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
						<h2>إنشاء حساب جديد</h2>
						<hr />
						<div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

						<!-- User Name -->
						<div class="form-floating mb-3">
							<input asp-for="Input.Name" class="form-control" placeholder="" />
							<label asp-for="Input.Name">اسم المستخدم</label>
							<span asp-validation-for="Input.Name" class="text-danger"></span>
						</div>

						<!-- Phone Number -->
						<div class="row g-2 mb-3">



							<!-- رقم الهاتف -->
							<div class="col-8 col-md-9">
								<div class="form-floating">
									<input asp-for="Input.UserName"
										   class="form-control"
										   placeholder="" id="Input_UserName" />
									<label asp-for="Input.UserName">رقم الهاتف</label>
								</div>
								<span asp-validation-for="Input.UserName" class="text-danger"></span>
							</div>

							<!-- رمز الدولة (غير مربوط بالموديل) -->
							<!-- رمز الدولة (غير مربوط بالموديل) -->
							<div class="col-4 col-md-3">
								<select id="countryCode"
										class="form-select phone-code" style="height:calc(3.5rem + calc(var(--bs-border-width) * 2))"
										asp-items="Model.CountryCodes">
								</select>

							</div>
						</div>




						<!-- Password -->
						<div class="form-floating mb-3">
							<input asp-for="Input.Password" type="password" class="form-control" autocomplete="new-password" placeholder="" />
							<label asp-for="Input.Password">كلمة المرور</label>
							<span asp-validation-for="Input.Password" class="text-danger"></span>
						</div>



						<button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary">إنشاء حساب</button>
					</form>
				</div>

			</div>

		</div>
	</div>
</div>

@section Scripts {


	<script>
		document.getElementById("registerForm").addEventListener("submit", function () {
			const code = document.getElementById("countryCode").value;
			const InputUserName = document.getElementById("Input_UserName");

			InputUserName.value = InputUserName.value.replace(/^0/, "");

			if (!InputUserName.value.startsWith("+")) {
				InputUserName.value = code + InputUserName.value;
			}
		});
	</script>

	<partial name="_ValidationScriptsPartial" />
}




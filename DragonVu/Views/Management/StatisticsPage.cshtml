@using DragonVu.Models
@model StatisticsVM

@{
    ViewData["Title"] = "StatisticsPage";
}

<div class="container mt-4 pb-5">
    <div class="row g-4">

        <!-- All Users -->
        <div class="col-md-4">
            <div class="card p-3 shadow">

                <h4>👤 المستخدمين : @Model.UserCount </h4>
                <ul class="list-group" style="max-height: 300px; overflow-y: auto;">
                    @foreach (var user in Model.allUsers)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">

                            <!-- User Info -->
                            <span>

                                @user.Name - @user.UserName
                            </span>
                            
                            <!-- One Form -->
                            <form asp-action="ManageUsers" method="post" class="d-flex gap-2">

                                <input type="hidden" name="id" value="@user.Id" />

                                <!-- Activate / Deactivate -->
                                @if (user.IsActive)
                                {
                                    <button type="submit" name="action" value="Deactivate"
                                            class="btn btn-success btn-sm">
                                        مدفوع
                                    </button>
                                }
                                else
                                {
                                    <button type="submit" name="action" value="Activate"
                                            class="btn btn-warning btn-sm">
                                        عادي
                                    </button>
                                }

                                <!-- Delete -->
                                <button type="submit" name="action" value="Delete"
                                        class="btn btn-danger btn-sm"
                                        onclick="return confirm('Are you sure?');">
                                    حذف
                                </button>

                            </form>

                        </li>
                    }
                </ul>

            </div>
        </div>

        <!-- Latest Users -->
        <div class="col-md-4">
            <div class="card p-3 shadow">
                <h4>🆕 المستخدمين الجدد</h4>
                <ul class="list-group">
                    @foreach (var user in Model.latestUsers)
                    {
                        <li class="list-group-item">
                            @user.Name - @user.UserName
                        </li>
                    }
                </ul>
                   
            </div>
        </div>

       
        <div class="col-md-4">
            <div class="card p-3 shadow">
                <h4>النتيجة</h4>
                <ul class="list-group">
                    @foreach (var res in Model.results)
                    {
                        <li class="list-group-item">
                            @res.Score - @res.Name - @res.Subject.Name
                        </li>
                    }
                </ul>
            </div>
        </div>

    </div>
</div>
@model IEnumerable<StatisticsVM>

@{
    ViewData["Title"] = "ManageUsers";
}

<h1>ManageUsers</h1>
<div>
    <table >
        <thead>
            <tr>
                <th>Username</th>
                <th>Email</th>
                <th>Role</th>
                <th>Actions</th>
			</tr>
            </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.allUsers</td>
                    <td></td>
                    
                    <td>
                        @* <a asp-action="EditUser" asp-route-id="@user.Id">Edit</a> |
                        <a asp-action="DeleteUser" asp-route-id="@user.Id">Delete</a> *@
                    </td>
                </tr>
            }
		</tbody>
    </table>
</div>

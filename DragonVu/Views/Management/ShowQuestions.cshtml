
@model IEnumerable<DragonVu.Models.Question>

@{
    ViewData["Title"] = "ShowQuestions";
}

<div class="d-flex justify-content-center align-items-center mt-4">
    <div class="card p-4" style=" max-width: 600px; width: 100%;">
        <h2 class="mb-4 text-center">الاسئلة</h2>
        <form method="get" asp-action="ShowQuestions">
            <div class="mb-3">
                <label class="form-label">اختر المادة</label>
                <select name="SubjectId"
                        class="form-select"
                        asp-items="ViewBag.Subjects"
                        onchange="this.form.submit()">

                    <option value="">-- كل المواد --</option>
                </select>
            </div>
        </form>


      
            @foreach (var q in Model)
        {
            <div class="card mb-4 p-3">
               
                <!-- ===== DISPLAY MODE ===== -->
                <div id="display-@q.Id">
                    @if (TempData["SuccessMessage"] != null
                                    && TempData["UpdatedQuestionId"] != null
                                    && (int)TempData["UpdatedQuestionId"] == q.Id)
                    {
                        <div class="alert alert-success alert-dismissible fade show text-center mt-3" role="alert">
                            @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <div class="mb-3 text-center">
                        <label>رقم السؤال: @q.Id</label>
                        <label class="mb-2">حالة السؤال: @q.Status.ToString()</label>
                        <div class="mb-2 text-center">
                            <span class="fw-bold">نص السؤال : </span>
                            <p>@q.Text</p>
                        </div>
                        
                        @* <img src="@Url.Content("~/" + q.ImageUrl)"
                             class="img-fluid mt-2"
                             style="max-height:300px;" /> *@
                        <img src="@Url.Content(string.IsNullOrEmpty(q.ImageUrl)
                                                        ? "~/images/default-question.png"
                                                        : "~/" + q.ImageUrl)"
                         class="img-fluid mt-2"
                         style="max-height:300px;" />
                    </div>
                    

                    

                    <div class="text-center">
                        @{
                            string answer = q.CorrectAnswer switch
                            {
                                1 => "A",
                                2 => "B",
                                3 => "C",
                                4 => "D",
                                _ => "Error"
                            };
                        }
                        <p>الإجابة الصحيحة: <strong>@answer</strong></p>
                    </div>
                    @*answers optional*@
                    <div class="mb-3">
                        <label class="form-label fw-bold">الإجابات:</label>
                        <div class="row g-2">
                            <div class="col-12 col-sm-6">
                                <div class="input-group">
                                    <span class="input-group-text">A</span>
                                    <input type="text" class="form-control" value="@q.AnswerA" readonly />
                                </div>
                            </div>
                            <div class="col-12 col-sm-6">
                                <div class="input-group">
                                    <span class="input-group-text">B</span>
                                    <input type="text" class="form-control" value="@q.AnswerB" readonly />
                                </div>
                            </div>
                            <div class="col-12 col-sm-6">
                                <div class="input-group">
                                    <span class="input-group-text">C</span>
                                    <input type="text" class="form-control" value="@q.AnswerC" readonly />
                                </div>
                            </div>
                            <div class="col-12 col-sm-6">
                                <div class="input-group">
                                    <span class="input-group-text">D</span>
                                    <input type="text" class="form-control" value="@q.AnswerD" readonly />
                                </div>
                            </div>
                        </div>
                    </div>
                    @* hint *@
                    
                    <div class="mb-3 text-center">
                        <label>التلميح : @q.Hint</label>
                    </div>



                    <div class="d-flex gap-2 mt-3">
                        <button type="button"
                                class="btn btn-success w-50"
                                onclick="showEdit(@q.Id)">
                            تعديل
                        </button>

                        <form asp-action="DeleteQuestion"
                        asp-controller="Quiz" 
                              method="post"
                              class="w-50">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@q.Id" />

                            <button type="submit" onclick="return confirm('هل أنت متأكد من الحذف ؟')" class="btn btn-danger w-100">
                                حذف
                            </button>
                            

                        </form>
                    </div>
                </div>


                <!-- ===== EDIT MODE ===== -->
                <div id="edit-@q.Id" style="display:none;">

                    <form asp-action="ShowQuestions"
                          method="post"
                          enctype="multipart/form-data">

                        <input type="hidden" name="Id" value="@q.Id" />

                        <!-- المادة -->
                        <div class="mb-3">
                            <label class="form-label">المادة</label>
                            <select name="SubjectId" required
                                    class="form-select"
                                    asp-items="ViewBag.Subjects">
                                <option value="@q.SubjectId">@q.Subject.Name</option>
                            </select >
                        </div>
                        @*text question*@
                        <div class="mb-3">
                            <label name="Text" class="form-label"> <i class="bi bi-card-text"></i> نص السؤال (اختياري) : </label>
                            <input name="Text" type="text" class="form-control" value="@q.Text">
                        </div>
                      

                        <!-- صورة جديدة -->
                        <div class="mb-3">
                            <label class="form-label">تغيير الصورة</label>
                            <input type="file"
                                   
                                   name="QuestionImage"
                                   class="form-control"
                                   accept="image/*" />
                        </div>

                        <!-- الإجابة -->
                        <div class="mb-3">
                            <label class="form-label">الإجابة الصحيحة</label>
                            <select required name="CorrectAnswer"
                                    class="form-select">
                                <option value="1" selected="@(q.CorrectAnswer == 1)">A</option>
                                <option value="2" selected="@(q.CorrectAnswer == 2)">B</option>
                                <option value="3" selected="@(q.CorrectAnswer == 3)">C</option>
                                <option value="4" selected="@(q.CorrectAnswer == 4)">D</option>
                            </select>
                        </div>

                        <!-- answers optinal -->
                        <div class="mb-3 mt-2">
                            <label class="form-label"> نص الاجابات (اختياري)</label>
                            <div class="mb-3 mt-2 d-flex align-items-center gap-3 flex-wrap">
                                <div class="d-flex align-items-center">
                                    <label class="me-1 fw-bold">A</label>
                                    <input class="form-control" style="width:150px; border-color:#348ceb" name="AnswerA" value="@q.AnswerA" />
                                </div>

                                <div class="d-flex align-items-center">
                                    <label class="me-1 fw-bold">B</label>
                                    <input class="form-control" style="width:150px; border-color:#348ceb" name="AnswerB" value="@q.AnswerB" />
                                </div>

                                <div class="d-flex align-items-center">
                                    <label class="me-1 fw-bold">C</label>
                                    <input class="form-control" style="width:150px; border-color:#348ceb" name="AnswerC" value="@q.AnswerC" />
                                </div>

                                <div class="d-flex align-items-center">
                                    <label class="me-1 fw-bold">D</label>
                                    <input class="form-control" style="width:150px; border-color:#348ceb" name="AnswerD" value="@q.AnswerD" />
                                </div>

                            </div>
                        </div>

                        <div class="mb-3">
                            <label name="Hint" class="form-label"> <i class="bi bi-lightbulb"></i> تلميح : </label>
                            <input name="Hint" type="text" class="form-control" value="@q.Hint">
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit"
                                    class="btn btn-primary w-50">
                                حفظ
                            </button>

                            <button type="button"
                                    class="btn btn-secondary w-50"
                                    onclick="hideEdit(@q.Id)">
                                إلغاء
                            </button>
                        </div>

                    </form>
                </div>

            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function showEdit(id) {
            document.getElementById("display-" + id).style.display = "none";
            document.getElementById("edit-" + id).style.display = "block";
        }

        function hideEdit(id) {
            document.getElementById("display-" + id).style.display = "block";
            document.getElementById("edit-" + id).style.display = "none";
        }
    </script>
}
@model StepQuizVM

@{
    int correct = Model.CurrentQuestion.CorrectAnswer;
    int selected = Model.SelectedAnswer ?? 0;
}

<style>
    .card {
        overflow-y: auto;
    }
</style>

<div class="container-fluid align-items-center mt-4" style="max-height: 80vh;">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6" style="max-width:550px">

            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="text-muted mb-0">
                            السؤال : @(Model.CurrentIndex + 1)
                        </h6>
                    </div>

                    <p class="fw-bold mb-3">
                        @Model.CurrentQuestion.Text
                    </p>

                    
                    <div class="text-center mb-4">
                        <img src="@(string.IsNullOrEmpty(Model.CurrentQuestion.ImageUrl)
                                             ? Url.Content("~/images/default-question.png")
                                             : Url.Content("~/" + Model.CurrentQuestion.ImageUrl))"
                             class="img-fluid rounded-3 shadow-sm"
                             style="max-height: 300px; object-fit: contain;" />
                    </div>

                    <form method="post">

                        <input type="hidden" name="CurrentIndex" value="@Model.CurrentIndex" />
                        <input type="hidden" name="Score" value="@Model.Score" />
                        <input type="hidden" name="QuestionId" value="@Model.CurrentQuestion.Id" />
                        <input type="hidden" name="SubjectId" value="@Model.SubjectId" />

                        @for (int i = 0; i < Model.QuestionIds.Count; i++)
                        {
                            <input type="hidden" name="QuestionIds[@i]" value="@Model.QuestionIds[i]" />
                        }

                        <div class="mb-3">
                            <label class="form-label fw-bold">اختر الإجابة الصحيحة:</label>

                            <div class="list-group">

                                <!-- A -->
                                <label class="list-group-item list-group-item-action
                                @(Model.ShowHint && correct == 1 ? "list-group-item-success" : "")
                                @(Model.ShowHint && selected == 1 && selected != correct ? "list-group-item-danger" : "")">

                                    <input class="form-check-input me-2"
                                           type="radio"
                                           name="SelectedAnswer"
                                           value="1"
                                           @(Model.ShowHint ? "disabled" : "required") />

                                    A : @Model.CurrentQuestion.AnswerA
                                </label>

                                <!-- B -->
                                <label class="list-group-item list-group-item-action
                                @(Model.ShowHint && correct == 2 ? "list-group-item-success" : "")
                                @(Model.ShowHint && selected == 2 && selected != correct ? "list-group-item-danger" : "")">

                                    <input class="form-check-input me-2"
                                           type="radio"
                                           name="SelectedAnswer"
                                           value="2"
                                           @(Model.ShowHint ? "disabled" : "") />

                                    B : @Model.CurrentQuestion.AnswerB
                                </label>

                                <!-- C -->
                                <label class="list-group-item list-group-item-action
                                @(Model.ShowHint && correct == 3 ? "list-group-item-success" : "")
                                @(Model.ShowHint && selected == 3 && selected != correct ? "list-group-item-danger" : "")">

                                    <input class="form-check-input me-2"
                                           type="radio"
                                           name="SelectedAnswer"
                                           value="3"
                                           @(Model.ShowHint ? "disabled" : "") />

                                    C : @Model.CurrentQuestion.AnswerC
                                </label>

                                <!-- D -->
                                <label class="list-group-item list-group-item-action
                                @(Model.ShowHint && correct == 4 ? "list-group-item-success" : "")
                                @(Model.ShowHint && selected == 4 && selected != correct ? "list-group-item-danger" : "")">

                                    <input class="form-check-input me-2"
                                           type="radio"
                                           name="SelectedAnswer"
                                           value="4"
                                           @(Model.ShowHint ? "disabled" : "") />

                                    D : @Model.CurrentQuestion.AnswerD
                                </label>

                            </div>
                        </div>

                        @if (Model.ShowHint)
                        {
                            <div class="alert alert-warning mt-3">
                                <strong>تلميح:</strong> @Model.CurrentQuestion.Hint
                            </div>

                            <div class="d-grid mt-4">
                                <button type="submit" name="Continue" value="true"
                                        class="btn btn-success btn-lg rounded-3">
                                    متابعة
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="d-grid mt-4">
                                <button type="submit" class="btn btn-primary btn-lg rounded-3">
                                    Submit Answer
                                </button>
                            </div>
                        }

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>
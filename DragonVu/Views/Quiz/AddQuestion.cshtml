@model DragonVu.Models.Question
@using DragonVu.Enums

<div class="d-flex justify-content-center align-items-center mt-5">
    <div class="card p-4" style=" max-width: 800px; width: 100%;">

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show text-center mt-3" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <h2 class="mb-4 text-center">إضافة سؤال جديد</h2>

        <form asp-action="AddQuestion" method="post" enctype="multipart/form-data">
            <!-- اختيار الموضوع -->
            <div class="mb-3">
                <label asp-for="SubjectId" class="form-label">المادة</label>
                <select required asp-for="SubjectId" class="form-select" asp-items="ViewBag.Subjects">
                    <option value="">-- اختر المادة --</option>
                </select>
                <span asp-validation-for="SubjectId" class="text-danger"></span>
            </div>

            <!-- نص السؤال -->
            <div class="mb-3">
                <label asp-for="Text" class="form-label">
                    <i class="bi bi-card-text"></i> نص السؤال :
                </label>
                <input asp-for="Text" required type="text" class="form-control" placeholder="ضع كلمة سؤال فقط لو سؤالك صمن الصورة فقط" id="QuestionText">
                <span asp-validation-for="Text" class="text-danger"></span>
            </div>

            <!-- رفع صورة السؤال -->
            <div class="mb-3">
                <label class="form-label">صورة السؤال</label>
                <input type="hidden" asp-for="ImageUrl" />

                <input type="file" id="QuestionImage" name="QuestionImage" class="form-control" accept="image/*" />
                <!-- معاينة الصورة -->
                <img id="imagePreview"
                     src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/default-question.png" : Model.ImageUrl)"
                     class="img-fluid mt-3"
                     style="max-height: 300px;" />
            </div>

            <!-- اختيار الإجابة الصحيحة -->
            <div class="mb-3">
                <label asp-for="CorrectAnswer" class="form-label">الإجابة الصحيحة</label>
                <select required asp-for="CorrectAnswer" class="form-select">
                    <option value="">-- اختر الإجابة الصحيحة --</option>
                    <option value="1">A</option>
                    <option value="2">B</option>
                    <option value="3">C</option>
                    <option value="4">D</option>
                </select>
                <span asp-validation-for="CorrectAnswer" class="text-danger"></span>
            </div>

            <!-- نص الإجابات -->
            <div class="mb-3 mt-2">
                <label class="form-label">نص الإجابات (اختياري)</label>
                <div class="mb-3 mt-2 d-flex align-items-center gap-3 flex-wrap">
                    <div class="d-flex align-items-center">
                        <label class="me-1 fw-bold">A</label>
                        <input class="form-control" style="width:150px; border-color:#348ceb" asp-for="AnswerA" />
                    </div>
                    <div class="d-flex align-items-center">
                        <label class="me-1 fw-bold">B</label>
                        <input class="form-control" style="width:150px; border-color:#348ceb" asp-for="AnswerB" />
                    </div>
                    <div class="d-flex align-items-center">
                        <label class="me-1 fw-bold">C</label>
                        <input class="form-control" style="width:150px; border-color:#348ceb" asp-for="AnswerC" />
                    </div>
                    <div class="d-flex align-items-center">
                        <label class="me-1 fw-bold">D</label>
                        <input class="form-control" style="width:150px; border-color:#348ceb" asp-for="AnswerD" />
                    </div>
                </div>
            </div>

            <!-- التلميح -->
            <div class="mb-3">
                <label asp-for="Hint" class="form-label"><i class="bi bi-lightbulb"></i> تلميح :</label>
                <input asp-for="Hint" type="text" class="form-control" placeholder="يمكن تركه فارغاً">
                <span asp-validation-for="Hint" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100">حفظ السؤال</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>

        
        const questionImageInput = document.getElementById('QuestionImage');
        const imagePreview = document.getElementById('imagePreview');

        questionImageInput.addEventListener('change', function() {
            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    imagePreview.setAttribute('src', e.target.result);
                    imagePreview.style.display = 'block';
                }
                reader.readAsDataURL(file);
            } else {
                imagePreview.src = "/images/default-question.png";
            }
        });
    </script>
}